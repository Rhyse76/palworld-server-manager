{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RhyseGaming Server Manager",
  "mainBinaryName": "RhyseGamingServerManager",
  "version": "0.4.10",
  "identifier": "com.palmanager.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RhyseGaming Server Manager",
        "width": 1160,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": "artifact-signing-cli -e https://cus.codesigning.azure.net -a Server-Manager -c Server-Manager %1"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzRENBRDJGN0FFNzA3QjQKUldTMEIrZDZMNjNjVXpjcHBpYWhnS0o3WnM2OTdacnZXeDdXdklZeXIrMkRZaDRCTFZwUTllZmkK",
      "endpoints": [
        "https://github.com/Rhyse76/palworld-server-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
